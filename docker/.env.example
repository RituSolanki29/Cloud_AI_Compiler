# ─────────────────────────────────────────────────────────────
#  SmartCloud — Environment Variables
#
#  Copy this file to docker/.env and fill in real values.
#  NEVER commit .env to Git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# PostgreSQL password (used by both postgres service and backend)
DB_PASSWORD=smartcloud_dev

# JWT signing secret — must be at least 32 characters
JWT_SECRET=mySecretKey12345678901234567890123456789012

# Your OpenAI API key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS (leave blank for local dev — S3 upload will be skipped)
AWS_REGION=us-east-1
S3_BUCKET=smartcloud-outputs
